{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_MARKETING_URL",
        "PORT",
        "AWS_REGION",
        "DATABASE_URL",
        "RESEND_API_KEY",
        "UBER_CLIENT_ID",
        "BETTER_AUTH_URL",
        "GOOGLE_CLIENT_ID",
        "UBER_CUSTOMER_ID",
        "AWS_ACCESS_KEY_ID",
        "STRIPE_SECRET_KEY",
        "AWS_S3_BUCKET_NAME",
        "BETTER_AUTH_SECRET",
        "UBER_CLIENT_SECRET",
        "GOOGLE_CLIENT_SECRET",
        "AWS_SECRET_ACCESS_KEY",
        "STRIPE_YEARLY_PRICE_ID",
        "UPSTASH_REDIS_REST_URL",
        "AWS_DEPLOYER_ACCESS_KEY",
        "AWS_DEPLOYER_SECRET_KEY",
        "STRIPE_MONTHLY_PRICE_ID",
        "STRIPE_ONE_TIME_PRICE_ID",
        "UPSTASH_REDIS_REST_TOKEN",
        "STRIPE_MONTHLY_PRODUCT_ID",
        "STRIPE_ONE_TIME_PRODUCT_ID",
        "STRIPE_API_VERSION"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "lint:check": {
      "dependsOn": ["^lint:check"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "type-check": {
      "dependsOn": ["^build", "^type-check"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "format": {
      "outputs": [".cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["PUBLIC_API_BASE_URL"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false,
      "dependsOn": ["db:generate"]
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["db:generate"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
