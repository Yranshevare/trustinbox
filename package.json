{
  "name": "monorepo-template",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:check": "turbo run lint:check",
    "format": "turbo format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "postinstall": "pnpm lint:ws",
    "lint:ws": "pnpm dlx sherif@latest -r packages-without-package-json -f",
    "type-check": "turbo run type-check",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "dev:marketing": "turbo run dev --filter=marketing",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "build:marketing": "turbo run build --filter=marketing",
    "db:generate": "turbo run db:generate --filter=api",
    "db:push": "turbo run db:push --filter=api",
    "db:migrate": "turbo run db:migrate --filter=api",
    "db:studio": "turbo run db:studio --filter=api",
    "prepare": "husky install",
    "commitlint": "commitlint --edit",
    "check-all": "pnpm run type-check && pnpm run lint && pnpm run format:check"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@repo/prettier-config": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "es-abstract": "^1.24.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.7.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.51.0"
  },
  "packageManager": "pnpm@9.0.0",
  "prettier": "@repo/prettier-config",
  "engines": {
    "node": ">=18"
  }
}
